    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Source Sans Pro', sans-serif;
            background: linear-gradient(135deg, #EFE7DB 0%, #f5f0e8 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .error-container {
            text-align: center;
            padding: 40px;
        }

        .error-code {
            font-family: 'Sofia Sans', sans-serif;
            font-size: 150px;
            font-weight: 600;
            color: #af0000;
            line-height: 1;
            text-shadow: 4px 4px 0 #d32f2f;
        }

        .error-message {
            font-size: 28px;
            color: #333;
            margin-top: 20px;
            margin-bottom: 10px;
        }

        .error-description {
            font-size: 18px;
            color: #666;
            margin-bottom: 40px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }

        .home-link {
            display: inline-block;
            padding: 15px 40px;
            background: linear-gradient(135deg, #af0000 0%, #d32f2f 100%);
