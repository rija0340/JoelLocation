<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Page non trouvée - JOEL LOCATION</title>
    <link rel="icon" type="image/x-icon" href="{{ asset('images/Joel-Location-new.png') }}" />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+Pro:wght@300;400;500;600;700&display=swap"
