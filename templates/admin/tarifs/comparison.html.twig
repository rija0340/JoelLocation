{% extends 'base2.html.twig' %}

{% block title %}Tarifs V2 - Comparison{% endblock %}

{% block stylesheets %}
<link href="{{ asset('css/admin/tarifs_v2.css') }}" rel="stylesheet">
<style>
    .v2-filter-row {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
    }
    .v2-filter-row .v2-form-group { margin-bottom: 0; flex: 1; min-width: 180px; }
    .v2-comparison-scroll { overflow-x: auto; }
    .v2-table td.v2-price-col {
        font-weight: 700;
        font-size: 15px;
        font-variant-numeric: tabular-nums;
    }
</style>
{% endblock %}

{% block current_page %}
<h2 style="display:flex;align-items:center;gap:10px;">
    <span style="background:var(--v2-primary);color:white;width:36px;height:36px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;">
        <i class="fa fa-columns"></i>
    </span>
    Tarifs V2 - Comparison
    {% if isV2Active %}
        <span class="v2-badge v2-badge-success"><i class="fa fa-check-circle"></i> V2 actif</span>
    {% endif %}
</h2>
{% endblock %}

{% block content %}
<div class="v2-wrapper">

    <!-- Tabs -->
    <div class="v2-tabs">
        <a href="{{ path('tarifs_v2_matrix') }}"><i class="fa fa-th"></i> Matrix</a>
        <a class="active" href="{{ path('tarifs_v2_comparison') }}"><i class="fa fa-columns"></i> Comparison</a>
        <a href="{{ path('tarifs_v2_intervals') }}"><i class="fa fa-sliders"></i> Intervals</a>
    </div>

    <!-- Filters -->
    <div class="v2-toolbar">
        <div class="v2-filter-row" style="flex:1;">
            <div class="v2-form-group">
                <label>Interval</label>
                <select id="interval-select" class="v2-form-control"></select>
            </div>
            <div class="v2-form-group">
                <label>Month</label>
                <select id="month-select" class="v2-form-control">
                    {% for month in months %}
                        <option value="{{ month }}" {% if month == 'Janvier' %}selected{% endif %}>{{ month }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        <div class="v2-sep"></div>
        <button class="v2-btn v2-btn-primary" id="btn-load-comparison">
            <i class="fa fa-search"></i> Load
        </button>
        <button class="v2-btn" id="btn-export-comparison">
            <i class="fa fa-download"></i> Export
        </button>
    </div>

    <!-- Statistics -->
    <div class="v2-stat-grid" id="statistics-row" style="display:none;">
        <div class="v2-stat-card accent-success">
            <p class="v2-stat-value" id="stat-min">-</p>
            <p class="v2-stat-label">Minimum</p>
        </div>
        <div class="v2-stat-card accent-primary">
            <p class="v2-stat-value" id="stat-max">-</p>
            <p class="v2-stat-label">Maximum</p>
        </div>
        <div class="v2-stat-card accent-warning">
            <p class="v2-stat-value" id="stat-avg">-</p>
            <p class="v2-stat-label">Average</p>
        </div>
        <div class="v2-stat-card">
            <p class="v2-stat-value" id="stat-count">-</p>
            <p class="v2-stat-label">Vehicles</p>
        </div>
    </div>

    <!-- Table -->
    <div class="v2-card">
        <div class="v2-comparison-scroll">
            <table class="v2-table" id="comparison-table">
                <thead>
                    <tr>
                        <th style="width:50px;">#</th>
                        <th>Vehicle</th>
                        <th style="text-align:right;">Price</th>
                        <th style="width:80px;"></th>
                    </tr>
                </thead>
                <tbody id="comparison-body">
                    <tr><td colspan="4">
                        <div class="v2-empty">
                            <i class="fa fa-columns"></i>
                            <p>Select interval &amp; month, then click Load</p>
                        </div>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- Loading -->
<div class="v2-loading" id="loading-overlay"><div class="v2-spinner"></div></div>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/admin/tarifs_v2_comparison.js') }}"></script>
{% endblock %}
