{% extends 'base2.html.twig' %}

{% block title %}Simulateur de tarifs | Luxe & Précision{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --secondary: #64748b;
            --success: #10b981;
            --info: #0ea5e9;
            --danger: #ef4444;
            --warning: #f59e0b;
            --background: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        body {
            background-color: var(--background);
            color: var(--text-main);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .simulator-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        .glass-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 1rem;
            box-shadow: var(--shadow);
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .mode-badge {
            padding: 0.5rem 1rem;
            border-radius: 9999px;
            font-weight: 600;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .mode-badge-v2 { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
        .mode-badge-v1 { background: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }

        .form-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        @media (max-width: 768px) {
            .form-section { grid-template-columns: 1fr; }
        }

        .input-group-custom {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .input-group-custom label {
            font-weight: 500;
            color: var(--text-main);
            font-size: 0.9rem;
        }

        .form-control-modern {
            padding: 0.75rem 1rem;
            border: 1px solid var(--border);
            border-radius: 0.5rem;
            font-size: 1rem;
            transition: border-color 0.2s, ring 0.2s;
            outline: none;
        }

        .form-control-modern:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        }

        .grid-selection {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .selectable-card {
            position: relative;
            padding: 1rem;
            border: 2px solid var(--border);
            border-radius: 0.75rem;
            cursor: pointer;
            transition: all 0.2s ease;
            background: #fff;
            user-select: none;
        }

        .selectable-card:hover {
            border-color: var(--primary);
            background: #f5f3ff;
        }

        .selectable-card.selected {
            border-color: var(--primary);
            background: #eef2ff;
            box-shadow: var(--shadow-sm);
        }

        .selectable-card input {
            position: absolute;
            opacity: 0;
        }

        .card-title {
            font-weight: 600;
            display: block;
            margin-bottom: 0.25rem;
        }

        .card-price {
            color: var(--primary);
            font-weight: 700;
            font-size: 1.1rem;
        }

        .btn-calculate {
            background: var(--primary);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 0.75rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: background 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.1rem;
            box-shadow: var(--shadow);
        }

        .btn-calculate:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }

        .results-section {
            margin-top: 3rem;
            display: none;
            animation: slideUp 0.4s ease-out;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .price-summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .summary-item {
            padding: 1.5rem;
            background: #fff;
            border-radius: 0.75rem;
            border: 1px solid var(--border);
            text-align: center;
        }

        .summary-label { color: var(--text-muted); font-size: 0.875rem; display: block; }
        .summary-value { font-weight: 700; font-size: 1.5rem; color: var(--text-main); }

        .grand-total-card {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            color: white;
            padding: 2rem;
            border-radius: 1rem;
            text-align: center;
            margin-top: 2rem;
        }

        .grand-total-value {
            font-size: 3rem;
            font-weight: 800;
            display: block;
            color: #38bdf8;
        }

        .modern-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-top: 1.5rem;
        }

        .modern-table th {
            text-align: left;
            padding: 1rem;
            background: #f1f5f9;
            font-weight: 600;
            color: var(--secondary);
            border-bottom: 2px solid var(--border);
        }

        .modern-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .mini-badge {
            padding: 0.25rem 0.6rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            background: #f1f5f9;
        }

        .loader {
            display: none;
            margin: 2rem auto;
            border: 4px solid #f3f3f3;
            border-top: 4px solid var(--primary);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .error-alert {
            display: none;
            background: #fef2f2;
            color: #991b1b;
            padding: 1rem;
            border-radius: 0.5rem;
            border: 1px solid #fecaca;
            margin: 1rem 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
    </style>
{% endblock %}

{% block content %}
<div class="simulator-container">
    <div class="header-section">
        <div>
            <h1 style="font-weight: 800; margin: 0; font-size: 2.25rem; letter-spacing: -0.025em;">
                Simulateur de Tarifs
            </h1>
            <p style="color: var(--text-muted); margin-top: 0.5rem;">Calculez instantanément le coût d'une location avec une précision totale.</p>
        </div>
        <div>
            {% if isV2Active %}
                <div class="mode-badge mode-badge-v2">
                    <i class="fa fa-bolt"></i> Mode V2 Inclusif
                </div>
            {% else %}
                <div class="mode-badge mode-badge-v1">
                    <i class="fa fa-clock-o"></i> Mode V1 Standard
                </div>
            {% endif %}
        </div>
    </div>

    <div class="glass-card" style="padding: 2.5rem;">
        <form id="simulateurForm">
            <div class="form-section">
                <div class="input-group-custom">
                    <label for="dateDepart">Date et Heure de Départ</label>
                    <input type="datetime-local" class="form-control-modern" id="dateDepart" name="dateDepart" required>
                </div>
                <div class="input-group-custom">
                    <label for="dateRetour">Date et Heure de Retour</label>
                    <input type="datetime-local" class="form-control-modern" id="dateRetour" name="dateRetour" required>
                </div>
            </div>

            <div class="input-group-custom" style="margin-bottom: 2rem;">
                <label for="vehicule">Choisir un Véhicule</label>
                <select class="form-control-modern" id="vehicule" name="vehiculeId" required>
                    <option value="">Sélectionnez le modèle phare...</option>
                    {% for vehicule in vehicules %}
                        <option value="{{ vehicule.id }}">
                            {{ vehicule.marque.libelle }} {{ vehicule.modele.libelle }} 
                            ({{ vehicule.immatriculation }})
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div style="margin-bottom: 2.5rem;">
                <label style="font-weight: 600; display: block; margin-bottom: 1rem;">Extras & Options Premium</label>
                <div class="grid-selection">
                    {% for option in options %}
                        <label class="selectable-card" id="opt-card-{{ option.id }}">
                            <input type="checkbox" name="options[]" value="{{ option.id }}" onchange="handleCardStyle(this)">
                            <span class="card-title">{{ option.appelation }}</span>
                            <span class="summary-label" style="margin-bottom: 0.5rem;">{{ option.description|default('Option confort')|slice(0, 40) }}...</span>
                            <span class="card-price">{{ option.prix }} €</span>
                        </label>
                    {% endfor %}
                    
                    <label class="selectable-card" id="opt-card-conducteur">
                        <input type="checkbox" name="hasConducteur" value="1" id="hasConducteur" onchange="handleCardStyle(this)">
                        <span class="card-title">2ème Conducteur</span>
                        <span class="summary-label" style="margin-bottom: 0.5rem;">Assurance partagée</span>
                        <span class="card-price">50 €</span>
                    </label>
                </div>
            </div>

            <div style="margin-bottom: 2.5rem;">
                <label style="font-weight: 600; display: block; margin-bottom: 1rem;">Garanties de Sérénité</label>
                <div class="grid-selection">
                    {% for garantie in garanties %}
                        <label class="selectable-card" id="gar-card-{{ garantie.id }}">
                            <input type="checkbox" name="garanties[]" value="{{ garantie.id }}" onchange="handleCardStyle(this)">
                            <span class="card-title">{{ garantie.appelation }}</span>
                            <span class="summary-label" style="margin-bottom: 0.5rem;">{{ garantie.description|default('Protection totale')|slice(0, 40) }}...</span>
                            <span class="card-price">{{ garantie.prix }} €</span>
                        </label>
                    {% endfor %}
                </div>
            </div>

            <div style="text-align: center; border-top: 1px solid var(--border); padding-top: 2rem;">
                <button type="submit" class="btn-calculate">
                    <i class="fa fa-magic"></i> Générer le tarif
                </button>
            </div>
        </form>

        <div class="loader" id="loadingSpinner"></div>
        <div class="error-alert" id="erreurBox">
            <i class="fa fa-exclamation-triangle"></i>
            <span id="errorMsg"></span>
        </div>

        <div class="results-section" id="resultatsBox">
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
                <div style="width: 4px; height: 32px; background: var(--primary); border-radius: 2px;"></div>
                <h3 style="margin: 0; font-weight: 700; font-size: 1.5rem;">Détails de votre Estimation</h3>
            </div>

            <!-- New Expressive Layout -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem;">
                <!-- Pure Rental Block -->
                <div class="glass-card" style="padding: 1.5rem; border-left: 4px solid var(--primary);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <span style="font-weight: 700; color: var(--primary);"><i class="fa fa-car"></i> Location Pure</span>
                        <span class="mini-badge" id="dureeBadgeResult">- jours</span>
                    </div>
                    <div style="font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem;" id="tarifVehiculeResult">-</div>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Tarif de base calculé selon le modèle et la saisonnalité.</p>
                </div>

                <!-- Options Block -->
                <div class="glass-card" style="padding: 1.5rem; border-left: 4px solid var(--info);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <span style="font-weight: 700; color: var(--info);"><i class="fa fa-plus-circle"></i> Options & Services</span>
                        <span id="optionsCountResult" class="mini-badge" style="background: #e0f2fe; color: #0ea5e9;">0</span>
                    </div>
                    <div style="font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem;" id="optionsTotalResult">-</div>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Équipements et services additionnels sélectionnés.</p>
                </div>

                <!-- Guarantees Block -->
                <div class="glass-card" style="padding: 1.5rem; border-left: 4px solid var(--success);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <span style="font-weight: 700; color: var(--success);"><i class="fa fa-shield"></i> Assurances & Garanties</span>
                        <span id="garantiesCountResult" class="mini-badge" style="background: #dcfce7; color: #10b981;">0</span>
                    </div>
                    <div style="font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem;" id="garantiesTotalResult">-</div>
                    <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Protections et couvertures pour votre trajet.</p>
                </div>
            </div>

            <div id="detailMoisSection" style="display: none; margin-bottom: 2.5rem;">
                <h4 style="font-weight: 600; color: var(--secondary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="fa fa-calendar-check-o"></i> 
                    Décomposition du Tarif Véhicule
                </h4>
                <div style="overflow-x: auto;" class="glass-card">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>MOIS</th>
                                <th>PÉRIODE</th>
                                <th>JOURS</th>
                                <th>BRACKET</th>
                                <th>TOTAL MOIS (TTC)</th>
                            </tr>
                        </thead>
                        <tbody id="detailMoisBody"></tbody>
                    </table>
                </div>
            </div>

            <div class="grand-total-card">
                <div style="display: flex; flex-direction: column; align-items: center;">
                    <span style="font-size: 1rem; text-transform: uppercase; letter-spacing: 0.2rem; margin-bottom: 0.5rem; color: #94a3b8;">Total Général Toutes Taxes Comprises</span>
                    <span class="grand-total-value" id="totalResult">-</span>
                    <div style="margin-top: 1.5rem; width: 100%; max-width: 400px; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.1); display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.9rem;">
                        <div style="text-align: right; color: rgba(255,255,255,0.6);">Location Pure :</div>
                        <div style="text-align: left; font-weight: 600;" id="finalVehiculeBreakdown">-</div>
                        <div style="text-align: right; color: rgba(255,255,255,0.6);">Suppléments :</div>
                        <div style="text-align: left; font-weight: 600;" id="finalSupplementsBreakdown">-</div>
                    </div>
                    <p style="margin-top: 2rem; opacity: 0.5; font-size: 0.75rem;">Cette estimation ne constitue pas un contrat. Les tarifs définitifs seront confirmés lors de la réservation.</p>
                </div>
            </div>

            <div style="margin-top: 2.5rem; padding: 1.5rem; border-radius: 0.75rem; background: #fefce8; border: 1px solid #fef08a; display: flex; gap: 1rem;">
                <i class="fa fa-info-circle" style="color: #ca8a04; font-size: 1.25rem;"></i>
                <div style="color: #854d0e; font-size: 0.9rem;">
                    {% if isV2Active %}
                        <strong>Logique V2 Active :</strong> Tarif basé sur des tranches journalières personnalisées avec un calcul de durée inclusif.
                    {% else %}
                        <strong>Logique V1 Active :</strong> Tarif basé sur des forfaits classiques (3j, 7j, 15j, 30j) avec calcul ISO.
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function handleCardStyle(input) {
    const card = input.closest('.selectable-card');
    if (input.checked) {
        card.classList.add('selected');
    } else {
        card.classList.remove('selected');
    }
}

document.getElementById('simulateurForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // UI states
    const loader = document.getElementById('loadingSpinner');
    const results = document.getElementById('resultatsBox');
    const errorBox = document.getElementById('erreurBox');
    const errorMsg = document.getElementById('errorMsg');
    
    loader.style.display = 'block';
    results.style.display = 'none';
    errorBox.style.display = 'none';
    
    const formData = new FormData(this);
    
    fetch('{{ path("tarifs_calculate") }}', {
        method: 'POST',
        body: formData,
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        loader.style.display = 'none';
        if (data.error) throw new Error(data.error);
        
        // Formatter for currency
        const fmt = (v) => v.toFixed(2) + ' €';

        // Populate Main expressive blocks
        document.getElementById('dureeBadgeResult').textContent = data.duree + ' JOURS';
        document.getElementById('tarifVehiculeResult').textContent = fmt(data.tarifVehicule);
        
        document.getElementById('optionsTotalResult').textContent = fmt(data.optionsTotal);
        document.getElementById('optionsCountResult').textContent = data.options.length + (formData.get('hasConducteur') ? 1 : 0);
        
        document.getElementById('garantiesTotalResult').textContent = fmt(data.garantiesTotal);
        document.getElementById('garantiesCountResult').textContent = data.garanties.length;
        
        // Final Total
        document.getElementById('totalResult').textContent = fmt(data.total);
        
        // Breakdown in Total Card
        document.getElementById('finalVehiculeBreakdown').textContent = fmt(data.tarifVehicule);
        document.getElementById('finalSupplementsBreakdown').textContent = fmt(data.optionsTotal + data.garantiesTotal);
        
        // Monthly breakdown table
        const body = document.getElementById('detailMoisBody');
        body.innerHTML = '';
        if (data.detailMois && data.detailMois.length > 0) {
            document.getElementById('detailMoisSection').style.display = 'block';
            data.detailMois.forEach(d => {
                body.innerHTML += `
                    <tr>
                        <td style="font-weight: 600;">${d.mois}</td>
                        <td style="color: var(--secondary); font-size: 0.9rem;">${d.dateDebut} <i class="fa fa-long-arrow-right"></i> ${d.dateFin}</td>
                        <td><span class="mini-badge">${d.jours} j</span></td>
                        <td><span style="font-size: 0.85rem; color: #6366f1;">${d.bracket}</span></td>
                        <td style="font-weight: 700;">${d.prix.toFixed(2)} €</td>
                    </tr>
                `;
            });
        } else {
            document.getElementById('detailMoisSection').style.display = 'none';
        }
        
        results.style.display = 'block';
        results.scrollIntoView({ behavior: 'smooth', block: 'start' });
    })
    .catch(err => {
        loader.style.display = 'none';
        errorMsg.textContent = err.message;
        errorBox.style.display = 'flex';
    });
});
</script>
{% endblock %}
